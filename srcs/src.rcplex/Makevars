OS=$(shell uname)
ARC=$(shell uname -m)

ifeq ($(OS),Darwin)
    ifeq ($(ARC),arm64)
        CPLEX_ARCH=arm64_osx
        PKG_CFLAGS=-fPIC -fno-strict-aliasing
    else
        CPLEX_ARCH=x86-64_osx
        PKG_CFLAGS=-m64 -fPIC -fno-strict-aliasing
    endif
else
    CPLEX_ARCH=x86-64_linux
    PKG_CFLAGS=-m64 -fPIC -fno-strict-aliasing
endif

PKG_CPPFLAGS=-I$(CPLEX_DIR)/cplex/include
PKG_LIBS=-L$(CPLEX_DIR)/cplex/lib/$(CPLEX_ARCH)/static_pic -lcplex -lm -lpthread
